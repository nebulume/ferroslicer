<?xml version="1.0" encoding="UTF-8"?>
<expert_prompt>
  <project_title>Advanced Custom Meshifying 3D Slicer for Lamp Printing Business</project_title>
  <project_description>
    Create a comprehensive Python application that converts 3D models (STL files) into custom G-code using a specialized meshifying vase mode for unique lamp printing applications. This is a PhD-level implementation with full modular design, performance optimization, and professional documentation.
  </project_description>
  
  <primary_objective>
    <goal>Convert STL (ASCII/text) or any 3D model into G-code using custom meshifying vase mode</goal>
    <application>Unique lamp 3D printing business with specialized mesh pattern requirements</application>
  </primary_objective>
  
  <core_functionality_requirements>
    <requirement>
      <id>001</id>
      <category>STL_Model_Processing</category>
      <description>Read and process STL models from current directory with interactive file selection</description>
      <specifications>
        <input_type>STL files (ASCII or binary)</input_type>
        <interface>Interactive file selection menu</interface>
        <file_selection_options>
          <option>1. lamp1.stl</option>
          <option>2. lamp2.stl</option>
          <option>...</option>
        </file_selection_options>
        <directory_handling>Current working directory</directory_handling>
      </specifications>
    </requirement>
    
    <requirement>
      <id>002</id>
      <category>Custom_Meshifying_Algorithm</category>
      <description>Implement specialized mesh pattern algorithm that creates holes in printed objects</description>
      <specifications>
        <algorithm_type>Custom meshifying vase mode</algorithm_type>
        <pattern_logic>
          <example>
            <layer>Layer 1</layer>
            <pattern>0, 1, 0, 1, 0</pattern>
            <axis>Y-axis coordinate transformation</axis>
          </example>
          <example>
            <layer>Layer 2</layer>
            <pattern>1, 0, 1, 0, 1</pattern>
            <axis>Y-axis coordinate transformation</axis>
          </example>
        </pattern_logic>
        <application>
          <application_type>Plane model example</application_type>
          <result>Mesh pattern with holes throughout the print</result>
        </application>
        <special_considerations>
          <consideration>Apply to vases and lampshades</consideration>
          <consideration>Non-watertight models</consideration>
        </special_considerations>
      </specifications>
    </requirement>
    
    <requirement>
      <id>003</id>
      <category>Dimension_Preservation</category>
      <description>Maintain critical inner dimensions during meshification process</description>
      <specifications>
        <critical_dimensions>
          <dimension>Base diameter: 90mm</dimension>
          <dimension>Mounting points: 90mm</dimension>
        </critical_dimensions>
        <preservation_methods>
          <method>Inner diameter integrity</method>
          <method>Base structure maintenance</method>
          <method>Mounting point preservation</method>
        </preservation_methods>
      </specifications>
    </requirement>
    
    <requirement>
      <id>004</id>
      <category>Progressive_Mesh_Design</category>
      <description>Implement progressive mesh pattern that starts with smaller gaps at bottom</description>
      <specifications>
        <base_height>
          <value>2-3 centimeters</value>
          <description>From bottom of model</description>
        </base_height>
        <mesh_growth>
          <description>Gradual increase in mesh size</description>
          <pattern>Smaller gaps at bottom, larger gaps at top</pattern>
        </mesh_growth>
      </specifications>
    </requirement>
    
    <requirement>
      <id>005</id>
      <category>G_Code_Generation</category>
      <description>Generate comprehensive G-code with verbose troubleshooting information</description>
      <specifications>
        <output_format>G-code with proper syntax</output_format>
        <verbosity>High verbosity for debugging</verbosity>
        <coordinate_system>
          <origin>Bottom left origin</origin>
          <build_volume>220x220x280mm</build_volume>
          <centering>Center on build plate</centering>
        </coordinate_system>
        <debugging>
          <step_by_step>Progressive processing information</step_by_step>
          <detailed_logging>Detailed debugging output</detailed_logging>
          <error_handling>Clear error messages</error_handling>
        </debugging>
      </specifications>
    </requirement>
  </core_functionality_requirements>
  
  <configuration_parameters>
    <parameter>
      <id>001</id>
      <name>Nozzle Size</name>
      <default>1mm</default>
      <type>float</type>
      <description>Printer nozzle diameter for proper calculations</description>
      <validation>Must be positive value</validation>
    </parameter>
    
    <parameter>
      <id>002</id>
      <name>Layer Thickness</name>
      <default>0.4mm</default>
      <type>float</type>
      <description>Print layer thickness for mesh pattern calculations</description>
      <validation>Must be positive value</validation>
    </parameter>
    
    <parameter>
      <id>003</id>
      <name>Base Height</name>
      <default>2-3cm</default>
      <type>float</type>
      <description>Height of bottom layer with less mesh pattern</description>
      <validation>Must be positive value</validation>
    </parameter>
    
    <parameter>
      <id>004</id>
      <name>Total Zigzag Points</name>
      <default>dynamic</default>
      <type>integer</type>
      <description>Number of zigzag points per circle layer</description>
      <dynamic_calculation>Based on model width at different layer sizes</dynamic_calculation>
      <validation>Must be positive integer</validation>
    </parameter>
    
    <parameter>
      <id>005</id>
      <name>Nozzle Temperature</name>
      <default>260°C</default>
      <type>integer</type>
      <description>Extruder temperature setting</description>
      <validation>Must be within printer limits</validation>
    </parameter>
    
    <parameter>
      <id>006</id>
      <name>Bed Temperature</name>
      <default>65°C</default>
      <type>integer</type>
      <description>Bed temperature setting</description>
      <validation>Must be within printer limits</validation>
    </parameter>
    
    <parameter>
      <id>007</id>
      <name>Print Speed</name>
      <default>35mm/s</default>
      <type>integer</type>
      <description>Printing speed in mm/s</description>
      <validation>Must be positive value</validation>
    </parameter>
    
    <parameter>
      <id>008</id>
      <name>Travel Speed</name>
      <default>40mm/s</default>
      <type>integer</type>
      <description>Travel speed between print moves</description>
      <validation>Must be positive value</validation>
    </parameter>
    
    <parameter>
      <id>009</id>
      <name>Fan Speed</name>
      <default>25%</default>
      <type>integer</type>
      <description>Cooling fan speed percentage</description>
      <validation>Must be between 0-100%</validation>
    </parameter>
    
    <parameter>
      <id>010</id>
      <name>Zigzag Offset</name>
      <default>2mm</default>
      <type>float</type>
      <description>Mesh hole size (total 4mm between furthest parts)</description>
      <validation>Must be positive value</validation>
    </parameter>
  </configuration_parameters>
  
